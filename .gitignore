# Rust build artifacts
/target/
**/*.rs.bk

# wasm-pack build output (wasm/) — regenerated by `npm run build:bundler`;
# wasm-pack also self-writes a `pkg/.gitignore` with `*`, this is belt-and-suspenders.
/wasm/pkg/
/wasm/pkg-node/

# Coverage output (cargo-llvm-cov)
/lcov.info
/*.profraw
/*.profdata

# Editor / IDE
.idea/
*.iml
.vscode/*
!.vscode/settings.json

# OS
.DS_Store
Thumbs.db
